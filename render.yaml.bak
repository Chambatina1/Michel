services:
  - type: web
    name: ps-medical-v2
    runtime: node
    plan: standard
    buildCommand: npx prisma generate && npm run build
    startCommand: node .next/standalone/server.js
    envVars:
      - key: NODE_ENV
        value: production
      - key: NEXT_TELEMETRY_DISABLED
        value: "1"
      - key: DEEPSEEK_API_KEY
        value: sk-7bb9cff20c1349a2b6c561b96da0b1c9
